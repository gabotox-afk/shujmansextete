generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  nombre    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Datos de onboarding
  onboardingCompleto Boolean @default(false)
  edad               Int?
  peso               Float?
  altura             Float?
  sexo               String?
  actividadFisica    Int?
  objetivo           String?

  alimentos      Alimento[]
  comidas        Comida[]
  ejercicios     Ejercicio[]
  rutinas        Rutina[]
  calendarios    Calendario[]
  sesiones       Sesion[]
  registrosPeso  RegistroPeso[]
}

// Catálogo de alimentos: macros por cada 100g.
// usuarioId == null  -> alimento del catálogo global (precargado)
// usuarioId != null  -> alimento personalizado, creado por ese usuario
model Alimento {
  id                   Int      @id @default(autoincrement())
  nombre               String
  kcalPor100g          Float
  proteinasPor100g     Float
  grasasPor100g        Float
  carbohidratosPor100g Float
  usuarioId            Int?
  usuario              Usuario? @relation(fields: [usuarioId], references: [id])
  items                ItemComida[]
  createdAt            DateTime @default(now())

  @@index([usuarioId])
}

// Una comida cargada por el usuario (desayuno, almuerzo, merienda, cena, snack),
// compuesta por uno o varios alimentos cargados "en lote". Las macros totales
// se obtienen sumando las de cada item.
model Comida {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  tipo      String   // desayuno | almuerzo | merienda | cena | snack
  nombre    String?  // nombre opcional para identificarla (ej: "Pollo con arroz")
  fecha     DateTime @default(now())
  createdAt DateTime @default(now())
  items     ItemComida[]

  @@index([usuarioId, fecha])
}

// Un alimento puntual dentro de una comida. Los macros se calculan y guardan
// "congelados" al momento de cargar (gramos * macro-por-100g / 100), así si
// el alimento de catálogo cambia más adelante, el historial no se altera.
model ItemComida {
  id            Int       @id @default(autoincrement())
  comidaId      Int
  comida        Comida    @relation(fields: [comidaId], references: [id], onDelete: Cascade)
  alimentoId    Int?
  alimento      Alimento? @relation(fields: [alimentoId], references: [id])
  nombre        String
  gramos        Float
  kcal          Float
  proteinas     Float
  grasas        Float
  carbohidratos Float
  createdAt     DateTime  @default(now())

  @@index([comidaId])
}

// ─── ENTRENAMIENTOS ───────────────────────────────────────────────────────────

// Catálogo de ejercicios: global (usuarioId null) + personalizados por usuario.
model Ejercicio {
  id            Int      @id @default(autoincrement())
  nombre        String
  grupoMuscular String   // pecho|espalda|hombros|biceps|triceps|cuadriceps|isquiotibiales|gluteos|core|cardio
  descripcion   String?
  usuarioId     Int?
  usuario       Usuario? @relation(fields: [usuarioId], references: [id])
  createdAt     DateTime @default(now())

  rutinaDiaEjercicios RutinaDiaEjercicio[]
  seriesRegistradas   SerieRegistrada[]

  @@index([usuarioId])
  @@index([grupoMuscular])
}

// Rutina: plan de entrenamiento (ej. "Mi Push/Pull/Legs").
model Rutina {
  id          Int       @id @default(autoincrement())
  usuarioId   Int
  usuario     Usuario   @relation(fields: [usuarioId], references: [id])
  nombre      String
  descripcion String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  dias        RutinaDia[]
  calendarios Calendario[]

  @@index([usuarioId])
}

// Un día dentro de una rutina (ej. "Push", "Pierna A").
model RutinaDia {
  id         Int      @id @default(autoincrement())
  rutinaId   Int
  rutina     Rutina   @relation(fields: [rutinaId], references: [id], onDelete: Cascade)
  nombre     String
  orden      Int
  diaSemana  Int?     // preset: qué día de la semana ocupa (1=lun…7=dom), null si no asignado
  createdAt  DateTime @default(now())

  ejercicios  RutinaDiaEjercicio[]
  calendarios Calendario[]
  sesiones    Sesion[]

  @@index([rutinaId])
}

// Slot de ejercicio dentro de un día de rutina, con objetivos de volumen.
model RutinaDiaEjercicio {
  id          Int       @id @default(autoincrement())
  rutinaDiaId Int
  rutinaDia   RutinaDia @relation(fields: [rutinaDiaId], references: [id], onDelete: Cascade)
  ejercicioId Int
  ejercicio   Ejercicio @relation(fields: [ejercicioId], references: [id])
  orden       Int
  seriesObj   Int       // series objetivo (ej: 4)
  repsObj     String    // reps objetivo (ej: "8-12" o "10")
  rirObj      Int?      // RIR objetivo (ej: 2)
  notas       String?

  @@index([rutinaDiaId])
}

// Schedule semanal recurrente: qué rutinaDia corresponde a cada día de semana.
// diaSemana: 1=lunes … 7=domingo (ISO). rutinaDiaId null = día de descanso.
model Calendario {
  id          Int        @id @default(autoincrement())
  usuarioId   Int
  usuario     Usuario    @relation(fields: [usuarioId], references: [id])
  diaSemana   Int
  rutinaDiaId Int?
  rutinaDia   RutinaDia? @relation(fields: [rutinaDiaId], references: [id])
  rutinaId    Int?
  rutina      Rutina?    @relation(fields: [rutinaId], references: [id])

  @@unique([usuarioId, diaSemana])
  @@index([usuarioId])
}

// Una sesión de entrenamiento completada o en curso.
model Sesion {
  id          Int        @id @default(autoincrement())
  usuarioId   Int
  usuario     Usuario    @relation(fields: [usuarioId], references: [id])
  rutinaDiaId Int?
  rutinaDia   RutinaDia? @relation(fields: [rutinaDiaId], references: [id])
  fecha       DateTime   @default(now())
  duracionMin Int?
  notas       String?
  completada  Boolean    @default(false)
  createdAt   DateTime   @default(now())

  series SerieRegistrada[]

  @@index([usuarioId, fecha])
}

// Registro de peso corporal con fecha para tracking histórico.
model RegistroPeso {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  fecha     DateTime @default(now())
  pesoKg    Float
  createdAt DateTime @default(now())

  @@index([usuarioId, fecha])
}

// Una serie registrada dentro de una sesión.
model SerieRegistrada {
  id          Int       @id @default(autoincrement())
  sesionId    Int
  sesion      Sesion    @relation(fields: [sesionId], references: [id], onDelete: Cascade)
  ejercicioId Int
  ejercicio   Ejercicio @relation(fields: [ejercicioId], references: [id])
  numeroSerie Int
  reps        Int
  pesoKg      Float
  rir         Int?
  createdAt   DateTime  @default(now())

  @@index([sesionId])
  @@index([ejercicioId])
}